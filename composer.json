{
    "name": "telegram-bot-dev/dating-bot",
    "type": "project",
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Dmytro Hniezdilov",
            "email": "wertyzp@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-intl": "*",
        "ext-pcntl": "*",
        "friendsofphp/php-cs-fixer": "dev-master",
        "laravel/lumen-framework": "^10.0",
        "league/flysystem-aws-s3-v3": "4.x-dev",
        "league/oauth2-client": "dev-master",
        "nyholm/psr7": "^1.8@dev",
        "openai-php/client": "dev-main",
        "symfony/http-client": "6.4.x-dev",
        "wertyzp/mapped-object": "dev-main",
        "wertyzp/telegram-bot-client": "dev-main"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "mockery/mockery": "^1.3.1",
        "phpunit/phpunit": "^9.5.10"
    },
    "scripts": {
        "php-cs-fixer": "php8.1 vendor/bin/php-cs-fixer"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
